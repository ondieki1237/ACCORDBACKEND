# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ═══════════════════════════════════════════════════════════
# MySQL Configuration (for migration)
# ═══════════════════════════════════════════════════════════

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=accord

# ═══════════════════════════════════════════════════════════
# MongoDB Configuration
# ═══════════════════════════════════════════════════════════

MONGODB_URI=mongodb://localhost:27017/accord

# For MongoDB Atlas cloud:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/accord?retryWrites=true&w=majority

# ═══════════════════════════════════════════════════════════
# Application Configuration
# ═══════════════════════════════════════════════════════════

NODE_ENV=development
PORT=4500
HOST=localhost

# ═══════════════════════════════════════════════════════════
# JWT Configuration
# ═══════════════════════════════════════════════════════════

JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this_too
JWT_REFRESH_EXPIRE=30d

# ═══════════════════════════════════════════════════════════
# Email Configuration (optional)
# ═══════════════════════════════════════════════════════════

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@accord.com

# ═══════════════════════════════════════════════════════════
# External APIs
# ═══════════════════════════════════════════════════════════

# KMHFR API Configuration
KMHFR_API_BASE=https://api.kmhfr.health.go.ke/api
KMHFR_API_TIMEOUT=10000
KMHFR_RETRY_ATTEMPTS=3
KMHFR_CACHE_TTL=3600

# Daraja STK Push
DARAJA_CONSUMER_KEY=your_daraja_key
DARAJA_CONSUMER_SECRET=your_daraja_secret
DARAJA_PASSKEY=your_daraja_passkey

# Google Services (if using)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ═══════════════════════════════════════════════════════════
# File Upload Configuration
# ═══════════════════════════════════════════════════════════

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx,xls,xlsx

# ═══════════════════════════════════════════════════════════
# Logging Configuration
# ═══════════════════════════════════════════════════════════

LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ═══════════════════════════════════════════════════════════
# Feature Flags
# ═══════════════════════════════════════════════════════════

ENABLE_KMHFR_SYNC=true
ENABLE_DARAJA_PAYMENT=true
ENABLE_AUTO_BACKUP=true

# ═══════════════════════════════════════════════════════════
# Notes for Migration
# ═══════════════════════════════════════════════════════════

# Before running migration:
# 1. Fill in MYSQL_* variables with your current MySQL database
# 2. Fill in MONGODB_URI with your MongoDB database
# 3. Test connection: mysql -h $MYSQL_HOST -u $MYSQL_USER -p
# 4. Test connection: mongosh "$MONGODB_URI"
# 5. Run: node migrate-users-mysql-to-mongo.js
